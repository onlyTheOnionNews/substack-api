{
  "name": "substackular",
  "version": "0.1.0",
  "description": "TypeScript client for the Substack API with flexible cookie authentication (substack.sid and/or connect.sid), notes publishing from markdown, and retry/backoff",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepare": "pnpm build",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:watch": "jest --watch",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "sample": "pnpm exec ts-node -r tsconfig-paths/register samples/index.ts"
  },
  "keywords": [
    "substack",
    "api",
    "client",
    "typescript",
    "notes",
    "mcp"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "dotenv": "^17.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-prettier": "^5.5.0",
    "jest": "^30.0.0",
    "jest-junit": "^17.0.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1",
    "tsup": "^8.3.5",
    "typescript": "^6.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "axios-rate-limit": "^1.4.0",
    "axios-retry": "^4.5.0",
    "fp-ts": "^2.16.10",
    "io-ts": "^2.2.22"
  }
}
